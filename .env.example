# Copy this file to `.env` and adjust the values if needed.
# Every variable has a default in src/rag/config.py — only set one to override it.

# --- Ollama / model ---
MODEL_LLM=llama3
MODEL_EMBEDDINGS=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# --- Data paths (default: <repo>/chroma_db, <repo>/papers) ---
# CHROMA_PATH=
# DEFAULT_FOLDER=

# --- Text splitting (RAG) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
